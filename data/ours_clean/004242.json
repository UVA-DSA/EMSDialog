    {
      "turn": 43,
      "topic": "Pain Assessment",
      "micro_intent": "O.P.Q.R.S.T. - severity",
      "role": "Patient",
      "utterance": "It's a 10. Especially when I move."
    },
    {
      "turn": 44,
      "topic": "Pain Assessment",
      "micro_intent": "O.P.Q.R.S.T. - radiation",
      "role": "EMT",
      "utterance": "Does it radiate anywhere else?"
    },
    {
      "turn": 45,
      "topic": "Pain Assessment",
      "micro_intent": "O.P.Q.R.S.T. - radiation",
      "role": "Patient",
      "utterance": "Yeah, all down my left side. Numbness all the way to my toes."
    },
    {
      "turn": 46,
      "topic": "Secondary Assessment",
      "micro_intent": "thorax_lungs - breath_sounds",
      "role": "EMT",
      "utterance": "I'm going to listen to your lungs now. Take a deep breath for me."
