{
  "source": "/scratch/zar8jw/Conversation_Generation/log/Qwen/Qwen3-32B/ours/004242",
  "protocol": [
    "injury - general trauma management (protocol 4 - 1)"
  ],
  "dialogue": [
    {
      "turn": 1,
      "topic": "Dispatch",
      "micro_intent": "radio_dispatch",
      "role": "dispatcher",
      "utterance": "Unit 3, respond to a traffic accident on Hall St and Hey Rd. Female in a vehicle reports neck pain and numbness."
    },
    {
      "turn": 2,
      "topic": "Introduction",
      "micro_intent": "introduction",
      "role": "EMT",
      "utterance": "Hi ma'am, I'm Alex, an EMT with the rescue squad. What made you call 911 today?"
    },
    {
      "turn": 3,
      "topic": "Chief Complaint",
      "micro_intent": "identify_primary_complaint",
      "role": "Patient",
      "utterance": "I was in a car accident. I've got neck pain and numbness down my left side."
    },
    {
      "turn": 4,
      "topic": "Responsiveness Exam",
      "micro_intent": "AVPU",
      "role": "EMT",
      "utterance": "Let's check how you're doing. Can you tell me your name, ma'am?"
    },
    {
      "turn": 5,
      "topic": "Responsiveness Exam",
      "micro_intent": "AVPU",
      "role": "Patient",
      "utterance": "Yes, my name is Rachel. I think I'm okay, just a little shaken up."
    },
    {
      "turn": 6,
      "topic": "Responsiveness Exam",
      "micro_intent": "AVPU",
      "role": "EMT",
      "utterance": "Where are we right now, Rachel?"
    },
    {
      "turn": 7,
      "topic": "Responsiveness Exam",
      "micro_intent": "AVPU",
      "role": "Patient",
      "utterance": "At Hey Rd and Hall St. I don't want to go back there."
    },
    {
      "turn": 8,
      "topic": "Responsiveness Exam",
      "micro_intent": "AVPU",
      "role": "EMT",
      "utterance": "What day is today, do you know, hun?"
    },
    {
      "turn": 9,
      "topic": "Responsiveness Exam",
      "micro_intent": "AVPU",
      "role": "Patient",
      "utterance": "I'm not sure. Probably the sixth of December."
    },
    {
      "turn": 10,
      "topic": "Responsiveness Exam",
      "micro_intent": "AVPU",
      "role": "EMT",
      "utterance": "What happened here today?"
    },
    {
      "turn": 11,
      "topic": "Responsiveness Exam",
      "micro_intent": "eye_opening",
      "role": "Paramedic",
      "utterance": "Marcus, let me have the penlight. Rachel, we're going to shine a light in your eyes to check your pupils."
    },
    {
      "turn": 12,
      "topic": "Responsiveness Exam",
      "micro_intent": "eye_opening",
      "role": "Patient",
      "utterance": "Okay."
    },
    {
      "turn": 13,
      "topic": "Responsiveness Exam",
      "micro_intent": "eye_opening",
      "role": "Paramedic",
      "utterance": "Both pupils are 3 mm, equal, and reactive."
    },
    {
      "turn": 14,
      "topic": "Responsiveness Exam",
      "micro_intent": "motor_response",
      "role": "Partner",
      "utterance": "Rachel, can you squeeze my hands? Left then right."
    },
    {
      "turn": 15,
      "topic": "Responsiveness Exam",
      "micro_intent": "motor_response",
      "role": "Patient",
      "utterance": "Sure. Let me try."
    },
    {
      "turn": 16,
      "topic": "Responsiveness Exam",
      "micro_intent": "motor_response",
      "role": "Partner",
      "utterance": "Left side isn't as strong. That numbness must be affecting you."
    },
    {
      "turn": 17,
      "topic": "Primary Assessment",
      "micro_intent": "check_airway",
      "role": "EMT",
      "utterance": "Airway is patent and you're maintaining it yourself."
    },
    {
      "turn": 18,
      "topic": "Primary Assessment",
      "micro_intent": "check_airway",
      "role": "Patient",
      "utterance": "Yeah, I can breathe fine now."
    },
    {
      "turn": 19,
      "topic": "Primary Assessment",
      "micro_intent": "check_breathing",
      "role": "EMT",
      "utterance": "Your breathing started pretty fast, but it's around 24 right now. Let's see."
    },
    {
      "turn": 20,
      "topic": "Take Vital Signs",
      "micro_intent": "resp",
      "role": "Partner",
      "utterance": "Respiration rate is 24 and breathing is non-labored."
    },
    {
      "turn": 21,
      "topic": "Primary Assessment",
      "micro_intent": "check_breathing",
      "role": "EMT",
      "utterance": "We'll listen to your lungs in just a moment."
    },
    {
      "turn": 22,
      "topic": "Take Vital Signs",
      "micro_intent": "pulse",
      "role": "Partner",
      "utterance": "Pulse is 120 and strong. All right, let's check your blood pressure."
    },
    {
      "turn": 23,
      "topic": "Take Vital Signs",
      "micro_intent": "bp",
      "role": "Partner",
      "utterance": "Blood pressure is 178 over 84. That's quite steady."
    },
    {
      "turn": 24,
      "topic": "Primary Assessment",
      "micro_intent": "check_circulation",
      "role": "EMT",
      "utterance": "Skin is warm, dry. Pulses are still strong."
    },
    {
      "turn": 25,
      "topic": "Take Vital Signs",
      "micro_intent": "spo2",
      "role": "Partner",
      "utterance": "Spo2 is 97% on room air."
    },
    {
      "turn": 26,
      "topic": "Take Vital Signs",
      "micro_intent": "glucose",
      "role": "Partner",
      "utterance": "We're unable to obtain a glucose reading at this time. Noted as 0, but not assessed further."
    },
    {
      "turn": 27,
      "topic": "Primary Assessment",
      "micro_intent": "check_circulation",
      "role": "EMT",
      "utterance": "SpO2 is consistent. No concern for oxygenation right now."
    },
    {
      "turn": 28,
      "topic": "History of Present Illness",
      "micro_intent": "S.A.M.P.L.E. - signs_and_symptoms",
      "role": "EMT",
      "utterance": "Rachel, can you tell me more about the pain you're having?"
    },
    {
      "turn": 29,
      "topic": "History of Present Illness",
      "micro_intent": "S.A.M.P.L.E. - signs_and_symptoms",
      "role": "Patient",
      "utterance": "It's pretty sharp in my neck, and it all went numb down my left side. It felt like something snapped."
    },
    {
      "turn": 30,
      "topic": "History of Present Illness",
      "micro_intent": "S.A.M.P.L.E. - signs_and_symptoms",
      "role": "EMT",
      "utterance": "When did you first notice the numbness?"
    },
    {
      "turn": 31,
      "topic": "History of Present Illness",
      "micro_intent": "S.A.M.P.L.E. - signs_and_symptoms",
      "role": "Patient",
      "utterance": "Right after the crash. It started in my leg and spread up."
    },
    {
      "turn": 32,
      "topic": "History of Present Illness",
      "micro_intent": "S.A.M.P.L.E. - signs_and_symptoms",
      "role": "EMT",
      "utterance": "Did you lose consciousness for a second at all?"
    },
    {
      "turn": 33,
      "topic": "History of Present Illness",
      "micro_intent": "S.A.M.P.L.E. - signs_and_symptoms",
      "role": "Patient",
      "utterance": "I think I did. Just for a blink."
    },
    {
      "turn": 34,
      "topic": "History of Present Illness",
      "micro_intent": "S.A.M.P.L.E. - signs_and_symptoms",
      "role": "EMT",
      "utterance": "I noticed you were hyperventilating earlier, but it seems to have improved now?"
    },
    {
      "turn": 35,
      "topic": "History of Present Illness",
      "micro_intent": "S.A.M.P.L.E. - signs_and_symptoms",
      "role": "Patient",
      "utterance": "Yes, it felt overwhelming, but I'm better after I slowed my breathing."
    },
    {
      "turn": 36,
      "topic": "History of Present Illness",
      "micro_intent": "S.A.M.P.L.E. - pertinent_past_medical_history",
      "role": "EMT",
      "utterance": "Do you have any past medical issues or ongoing health problems?"
    },
    {
      "turn": 37,
      "topic": "History of Present Illness",
      "micro_intent": "S.A.M.P.L.E. - pertinent_past_medical_history",
      "role": "Patient",
      "utterance": "Mild asthma."
    },
    {
      "turn": 38,
      "topic": "History of Present Illness",
      "micro_intent": "S.A.M.P.L.E. - pertinent_past_medical_history",
      "role": "EMT",
      "utterance": "Are you taking any medicines for that?"
    },
    {
      "turn": 39,
      "topic": "History of Present Illness",
      "micro_intent": "S.A.M.P.L.E. - pertinent_past_medical_history",
      "role": "Patient",
      "utterance": "Sometimes I take an inhaler."
    },
    {
      "turn": 40,
      "topic": "History of Present Illness",
      "micro_intent": "S.A.M.P.L.E. - pertinent_past_medical_history",
      "role": "EMT",
      "utterance": "Much better now?"
    },
    {
      "turn": 41,
      "topic": "History of Present Illness",
      "micro_intent": "S.A.M.P.L.E. - pertinent_past_medical_history",
      "role": "Patient",
      "utterance": "Yeah, I used an inhaler after the accident. That helped."
    },
    {
      "turn": 42,
      "topic": "Pain Assessment",
      "micro_intent": "O.P.Q.R.S.T. - severity",
      "role": "EMT",
      "utterance": "On a scale of 0 to 10, 10 being the worst, how bad is the pain right now?"
