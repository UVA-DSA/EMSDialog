    {
      "turn": 73,
      "topic": "Handoff",
      "micro_intent": "care_over_to_er",
      "role": "Paramedic",
      "utterance": "Pt had a brief episode at impact of possibly blacking out, but is now alert and oriented (A&Ox4). No signs of deterioration."
    },
    {
      "turn": 74,
      "topic": "Handoff",
      "micro_intent": "care_over_to_er",
      "role": "EMT",
      "utterance": "Vitals are stable en route. Cervical collar remains in place and is still well-fitted."
    },
    {
      "turn": 75,
      "topic": "Transport",
      "micro_intent": "movement_secured",
      "role": "EMT",
      "utterance": "Taking off safely now. Talk to you at the hospital, Rachel."
    },
    {
      "turn": 76,
      "topic": "Transport",
      "micro_intent": "movement_secured",
      "role": "Patient",
      "utterance": "Take it easy. Drive safe."
    },
    {
      "turn": 77,
      "topic": "Handoff",
      "micro_intent": "care_over_to_er",
      "role": "Paramedic",
      "utterance": "Suspected neck injury with left-sided numbness and midline tenderness. Trauma protocol is in effect."
    },
    {
      "turn": 78,
      "topic": "Handoff",
      "micro_intent": "care_over_to_er",
      "role": "EMT",
      "utterance": "No significant changes during transport. Pre-hospital care included C-spine stabilization and cervical collar placement."
    },
    {
      "turn": 79,
      "topic": "Handoff",
      "micro_intent": "care_over_to_er",
      "role": "EMT",
      "utterance": "Lungs were clear at last assessment. Oxygen saturation improved. Pt was given Albuterol with a good response."
    },
    {
      "turn": 80,
      "topic": "Handoff",
      "micro_intent": "care_over_to_er",
      "role": "Paramedic",
      "utterance": "Provided reassurance, kept pt comfortable, and maintained ABC stability during movement and transport."
    },
    {
      "turn": 81,
      "topic": "Handoff",
      "micro_intent": "care_over_to_er",
      "role": "EMT",
      "utterance": "All right, bedded and ready at Chippenham ER. Good luck to you."
