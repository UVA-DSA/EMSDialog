    {
      "turn": 48,
      "topic": "Secondary Assessment",
      "micro_intent": "thorax_lungs - breath_sounds",
      "role": "EMT",
      "utterance": "You had some wheezing earlier, but it's getting better after the Albuterol."
    },
    {
      "turn": 49,
      "topic": "Secondary Assessment",
      "micro_intent": "skin_exam",
      "role": "Paramedic",
      "utterance": "Let me check your skin a bit more. Do you have any rashes or major redness?"
